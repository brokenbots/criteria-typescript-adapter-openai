{
  "name": "criteria-adapter-openai",
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "build": "bun build --compile index.ts --outfile out/adapter",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 index.ts --outfile out/adapter-linux-amd64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 index.ts --outfile out/adapter-linux-arm64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 index.ts --outfile out/adapter-darwin-arm64",
    "test": "bun test",
    "clean": "rm -rf out/"
  },
  "dependencies": {
    "@criteria/adapter-sdk": "file:../criteria-typescript-adapter-sdk",
    "openai": "^4.85.0"
  },
  "trustedDependencies": [
    "protobufjs"
  ]
}
